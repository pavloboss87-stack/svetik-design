# Public site URL used by SEO/canonical/sitemap and as the CORS origin
# allowed by the Submit Worker.
PUBLIC_SITE_URL=

# Yandex.Metrica counter ID. If empty, the analytics script is not rendered
# (T22 graceful no-op). Activated by Svetlana via the activation checklist.
PUBLIC_METRIKA_ID=

# Submit Worker URL — POST endpoint used by ContactForm. Format:
# https://submit.svetik-design.<account>.workers.dev
PUBLIC_SUBMIT_URL=

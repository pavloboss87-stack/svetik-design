---
import { render, getEntry } from 'astro:content';

const entry = await getEntry('pages', 'hero');
if (!entry) throw new Error('pages/hero entry not found');
const { Content } = await render(entry);
---

<section class="border-b border-neutral-200 bg-white">
  <div class="mx-auto max-w-3xl px-6 py-24 md:py-32">
    <h1 class="font-display text-4xl leading-tight tracking-tight text-neutral-900 md:text-6xl">
      {entry.data.title}
    </h1>
    <div class="prose prose-neutral mt-8 max-w-2xl text-lg leading-relaxed text-neutral-700">
      <Content />
    </div>
  </div>
</section>

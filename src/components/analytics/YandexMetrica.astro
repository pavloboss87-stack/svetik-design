---
const counterId = import.meta.env.PUBLIC_METRIKA_ID?.trim();
const numericId = counterId ? Number(counterId) : NaN;
const isValidId = Number.isInteger(numericId) && numericId > 0;
---

{
  isValidId && (
    <Fragment>
      <script
        type="text/javascript"
        is:inline
        set:html={`
(function () {
  var COUNTER_ID = ${numericId};
  var CONSENT_KEY = 'consent.metrica.v1';
  var loaded = false;
  function initYM() {
    if (loaded) return;
    loaded = true;
    (function (m, e, t, r, i, k, a) {
      m[i] = m[i] || function () { (m[i].a = m[i].a || []).push(arguments); };
      m[i].l = 1 * new Date();
      for (var j = 0; j < e.scripts.length; j++) {
        if (e.scripts[j].src === r) return;
      }
      k = e.createElement(t); a = e.getElementsByTagName(t)[0];
      k.async = 1; k.src = r; a.parentNode.insertBefore(k, a);
    })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');
    window.ym(COUNTER_ID, 'init', {
      clickmap: true,
      trackLinks: true,
      accurateTrackBounce: true,
      webvisor: true
    });
  }
  try {
    if (localStorage.getItem(CONSENT_KEY) === 'granted') {
      initYM();
      return;
    }
  } catch (_) { /* localStorage blocked — wait for explicit consent */ }
  window.addEventListener('consent:metrica:granted', initYM, { once: true });
})();
        `}
      />
      <noscript>
        <div>
          <img
            src={`https://mc.yandex.ru/watch/${numericId}`}
            style="position:absolute; left:-9999px;"
            alt=""
          />
        </div>
      </noscript>
    </Fragment>
  )
}

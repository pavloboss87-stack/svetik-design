---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { formatArea, formatYear, localeProjectType } from '../../lib/format';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, id } = project;
const href = `/works/${id}/`;
---

<article class="group flex flex-col">
  <a href={href} class="block focus:outline-none">
    <div class="relative overflow-hidden bg-neutral-100">
      <Image
        src={data.cover}
        alt={data.title}
        widths={[400, 600, 800]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        class="aspect-[4/3] w-full object-cover transition group-hover:opacity-90"
      />
      {
        data.isConcept && (
          <span class="absolute left-3 top-3 rounded-sm bg-white/90 px-2 py-1 text-xs font-medium text-neutral-800 shadow-sm">
            Концепт-проект · фото в обработке
          </span>
        )
      }
    </div>
    <div class="mt-4">
      <h2 class="font-display text-xl leading-snug text-neutral-900 group-hover:text-neutral-600">
        {data.title}
      </h2>
      <p class="mt-1 text-sm text-neutral-600">
        {localeProjectType(data.type)} · {formatArea(data.area)} · {formatYear(data.year)}
        {data.location ? ` · ${data.location}` : ''}
      </p>
      <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-neutral-700">
        {data.summary}
      </p>
    </div>
  </a>
</article>

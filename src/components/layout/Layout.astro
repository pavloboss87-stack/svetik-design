---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import MetaTags from '../seo/MetaTags.astro';
import SchemaPerson from '../seo/SchemaPerson.astro';
import YandexMetrica from '../analytics/YandexMetrica.astro';
import CookieBanner from '../ui/CookieBanner.astro';

// ep02 T05 — preload-hints для критических шрифтов первого экрана.
// Подтягиваем .woff2 как ESM-импорт, чтобы Astro подставил fingerprinted
// путь и preload-link указывал ровно на тот же URL, который грузит CSS.
// Preload-им ровно два файла: PT Serif cyrillic 400 (display) и Inter
// cyrillic 400 (body). 700-вес PT Serif и 500/600 Inter не preload-им —
// font-display:swap справится со стилевыми вариантами.
import ptSerifCyrillic400 from '@fontsource/pt-serif/files/pt-serif-cyrillic-400-normal.woff2?url';
import interCyrillic400 from '@fontsource/inter/files/inter-cyrillic-400-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />

    <MetaTags title={title} description={description} ogImage={ogImage} canonical={canonical} />

    <link rel="preload" as="font" type="font/woff2" href={ptSerifCyrillic400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interCyrillic400} crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <SchemaPerson />
    <YandexMetrica />
  </head>
  <body class="flex min-h-screen flex-col bg-white font-sans text-neutral-900">
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
    <CookieBanner />
  </body>
</html>

---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import MetaTags from '../seo/MetaTags.astro';
import SchemaPerson from '../seo/SchemaPerson.astro';
import YandexMetrica from '../analytics/YandexMetrica.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />

    <MetaTags title={title} description={description} ogImage={ogImage} canonical={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <SchemaPerson />
    <YandexMetrica />
  </head>
  <body class="flex min-h-screen flex-col bg-white font-sans text-neutral-900">
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
  </body>
</html>

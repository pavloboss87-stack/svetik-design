---
import { getEntry, render } from 'astro:content';
import Layout from '../components/layout/Layout.astro';
import ContactChannels from '../components/contact/ContactChannels.astro';
import ContactForm from '../components/contact/ContactForm.astro';

const intro = await getEntry('pages', 'contact-intro');
if (!intro) throw new Error('pages/contact-intro entry not found');
const { Content: IntroContent } = await render(intro);
---

<Layout
  title="Контакты — Светлана Головина"
  description="Telegram, VK, Max, почта. Отвечаю в течение дня."
>
  <article class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <h1 class="font-display text-4xl tracking-tight text-neutral-900 md:text-5xl">
      {intro.data.title}
    </h1>

    <div class="mt-10 grid gap-12 md:grid-cols-2">
      <div>
        <div class="prose prose-neutral max-w-none text-base leading-relaxed text-neutral-800">
          <IntroContent />
        </div>
        <ContactForm />
      </div>

      <ContactChannels />
    </div>
  </article>
</Layout>

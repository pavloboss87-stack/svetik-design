---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../components/layout/Layout.astro';
import ServiceCard from '../components/services/ServiceCard.astro';

const intro = await getEntry('pages', 'services-intro');
if (!intro) throw new Error('pages/services-intro entry not found');
const { Content: IntroContent } = await render(intro);

const services = (await getCollection('services'))
  .filter((s) => s.data.published !== false)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Услуги — Светлана Головина"
  description="Полный дизайн-проект, авторский надзор и консультация. Стоимость обсуждается под объект."
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <h1 class="font-display text-4xl tracking-tight text-neutral-900 md:text-5xl">
      {intro.data.title}
    </h1>

    <div class="prose prose-neutral mt-6 max-w-none text-base leading-relaxed text-neutral-800">
      <IntroContent />
    </div>

    <div class="mt-12">
      {
        services.length === 0 ? (
          <p class="text-neutral-700">Услуги в разработке.</p>
        ) : (
          services.map((service) => <ServiceCard service={service} />)
        )
      }
    </div>
  </article>
</Layout>

---
import Layout from '../components/layout/Layout.astro';
---

<Layout title="Страница не найдена — Светлана Головина" description="Адреса нет или он изменился.">
  <section class="mx-auto flex max-w-2xl flex-col items-start gap-6 px-6 py-24 md:py-32">
    <p class="font-display text-6xl text-neutral-300">404</p>
    <h1 class="font-display text-3xl tracking-tight text-neutral-900 md:text-4xl">
      Страница не найдена
    </h1>
    <p class="text-base text-neutral-700">
      Адреса нет или он изменился. Вернитесь на <a href="/" class="underline hover:text-neutral-900"
        >главную</a
      > или посмотрите <a href="/works/" class="underline hover:text-neutral-900">работы</a>.
    </p>
  </section>
</Layout>

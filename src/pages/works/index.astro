---
import { getCollection } from 'astro:content';
import Layout from '../../components/layout/Layout.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import { isPublishedProject, sortProjects } from '../../lib/sortProjects';

const projects = sortProjects((await getCollection('projects')).filter(isPublishedProject));
---

<Layout
  title="Работы — Светлана Головина"
  description="Концепт-проекты квартир, студии и небольшого дома. Визуализации в Homestyler с watermark, описания пишутся."
>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <header class="mb-12 max-w-2xl">
      <h1 class="font-display text-4xl tracking-tight text-neutral-900 md:text-5xl">Работы</h1>
      <p class="mt-4 text-base text-neutral-700">
        Четыре концепт-проекта. Фото подписаны watermark и заменяются после ретуши; тексты автор
        пишет по ходу.
      </p>
    </header>

    {
      projects.length === 0 ? (
        <p class="text-neutral-700">Проекты в работе. Скоро появятся.</p>
      ) : (
        <ul class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <li>
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
